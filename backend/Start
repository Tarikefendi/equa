spec:
  user_authentication:
    goal: "Implement secure user authentication for the boycott platform"
    modules:
      - name: "User Registration"
        constraints:
          - "Users must register with verified ID numbers"
          - "Prevent duplicate accounts"
          - "Encrypt sensitive data"
          - "Support blockchain-based identity verification"
      - name: "Login System"
        constraints:
          - "Support email + password login"
          - "Use JWT tokens for session management"
          - "Provide secure password reset"
          - "Enable two-factor authentication (2FA)"
      - name: "Bot Prevention"
        constraints:
          - "Implement CAPTCHA or equivalent"
          - "Detect and block suspicious activity"
      - name: "Privacy Layer"
        constraints:
          - "Ensure user data is stored securely"
          - "Comply with GDPR-like privacy standards"
          - "Allow users to delete their accounts"
          - "Votes must remain anonymous but verifiable"
      - name: "Blockchain Identity Verification"
        constraints:
          - "Integrate with decentralized identity providers (DID)"
          - "Verify identity through blockchain attestations"
          - "Support multiple blockchain networks (Ethereum, Polygon)"
          - "Store identity hashes on-chain for verification"
          - "Enable zero-knowledge proof verification"
      - name: "Two-Factor Authentication"
        constraints:
          - "Support TOTP (Time-based One-Time Password)"
          - "Enable SMS-based verification as backup"
voting_system:
    goal: "Implement a secure and transparent voting system for boycott campaigns"
    modules:
      - name: "Voting System"
        constraints:
          - "Allow users to vote anonymously but verifiably"
          - "Prevent duplicate or fraudulent votes"
          - "Display real-time vote counts and campaign results"
          - "Support both boycott and support campaigns"
          - "Enable vote tracking per company, brand, and government entity"
          - "Integrate with blockchain for vote integrity and auditability"
          - "Allow users to view their own voting history"
          - "Support vote revocation and re-voting within campaign window"
          - "Visualize vote impact through charts and metrics"
implementation:
  final_review:
    optimization_status: "pending"

  testing:
    system_integration: "in_progress"
    end_to_end:
      user_journeys:
        - name: "new_user_onboarding"
          steps: ["registration", "identity_verification", "2fa_setup", "first_vote"]
          success_criteria: ["< 5 minutes completion", "< 2% dropout rate", "successful verification"]
        - name: "campaign_creation_lifecycle"
          steps: ["proposal_draft", "evidence_submission", "community_review", "campaign_launch", "voting", "results"]
          success_criteria: ["seamless transitions", "data consistency", "real-time updates"]
        - name: "governance_participation"
          steps: ["proposal_submission", "community_discussion", "voting", "implementation"]
          success_criteria: ["transparent process", "accurate vote counting", "proper execution"]

  integration:
    cross_module_auth:
      test_scenarios: ["sso_across_modules", "session_persistence", "permission_inheritance"]
      validation_points: ["consistent_user_state", "secure_token_handling", "proper_logout"]
    data_flow:
      vote_to_analytics: "verify vote data flows correctly to analytics dashboard"
      forum_to_notifications: "validate forum activity triggers appropriate notifications"
      campaign_to_blockchain: "ensure campaign data is properly recorded on blockchain"
    api_consistency:
      response_format_validation: "consistent JSON structure across all endpoints"
      error_handling_validation: "standardized error responses and codes"
      authentication_validation: "consistent auth requirements across APIs"
blockchain_identity:
    did_providers:
      - provider: "ION (Microsoft)"
        network: "Bitcoin"
        features: ["decentralized_identifiers", "verifiable_credentials"]
      - provider: "Ceramic Network"
        network: "Ethereum"
        features: ["self_sovereign_identity", "data_streams"]
      - provider: "Polygon ID"
        network: "Polygon"
        features: ["zero_knowledge_proofs", "privacy_preserving"]

    verification_flow:
      steps:
        - "User creates/imports DID wallet"
        - "Request identity attestation from trusted issuer"
        - "Generate zero-knowledge proof of identity"
        - "Submit proof hash to smart contract"
        - "Verify proof on-chain without revealing personal data"

    smart_contracts:
      identity_registry:
        networks: ["Ethereum", "Polygon"]
        functions:
          - "registerIdentity(bytes32 identityHash)"
          - "verifyIdentity(address user) returns (bool)"
          - "revokeIdentity(address user)"
      voting_eligibility:
        networks: ["Ethereum", "Polygon"]
        functions:
          - "checkEligibility(address user) returns (bool)"
          - "recordVote(bytes32 voteHash, bytes32 nullifier)"

auth_2fa:
  totp:
    library: "speakeasy"
    qr_generation: "qrcode"
    backup_codes:
      count: 10
      length: 8
      encryption: "AES-256-GCM"
  sms_backup:
    provider: "Twilio"
    rate_limiting: "3 attempts per 15 minutes"
    verification_window: "5 minutes"
  hardware_keys:
    protocol: "FIDO2/WebAuthn"
    supported_devices: ["YubiKey", "Google Titan", "SoloKeys"]
    attestation_verification: true
  biometric_auth:
    web_api: "WebAuthn"
    mobile_integration: "TouchID/FaceID"
    fallback_methods: ["TOTP", "SMS", "recovery_codes"]

security:
  encryption:
    at_rest: "AES-256-GCM"
    in_transit: "TLS 1.3"
  key_management: "AWS KMS / HashiCorp Vault"
  session_management:
    jwt_algorithm: "RS256"
    token_expiry:
      access: "15 minutes"
      refresh: "7 days"
    rotation_policy: "automatic on each use"
  privacy_compliance:
    data_minimization: "collect only necessary identity proofs"
    right_to_erasure: "delete personal data, keep anonymized vote records"
    consent_management: "granular permissions for data usage"

voting:
    anonymous_voting:
      zk_proofs:
        protocol: "zk-SNARKs"
        libraries: ["circom", "snarkjs", "circomlib"]
        circuits:
          - "vote_eligibility.circom"
          - "vote_uniqueness.circom"
          - "vote_validity.circom"
      nullifier_system:
        generation: "Poseidon(user_secret || campaign_id || domain_tag)"
        storage: "merkle tree on-chain"
        prevents: "double voting without revealing identity"
      commitment_scheme:
        vote_commitment: "Pedersen commitment"
        reveal_phase: "optional for transparency"
        hiding_property: "vote choice remains private"

    blockchain_integration:
      vote_storage:
        networks: ["Ethereum", "Polygon", "Arbitrum"]
        contract: "VotingRegistry"
        functions:
          - "submitVote(bytes32 nullifier, bytes32 commitment, bytes proof)"
          - "verifyVote(bytes32 nullifier) returns (bool)"
          - "getCampaignResults(uint256 campaignId) returns (uint256[])"
      merkle_tree_votes:
        implementation: "Incremental Merkle Tree"
        leaf_structure: "hash(nullifier, commitment, timestamp)"
        batch_updates: "every 100 votes or 10 minutes"

    campaign_management:
      types:
        - name: "boycott"
          options: ["support_boycott", "oppose_boycott", "neutral"]
        - name: "support"
          options: ["strongly_support", "support", "neutral", "oppose"]
        - name: "awareness"
          options: ["aware", "will_research", "not_interested"]
      target_entities:
        companies:
          fields: ["name", "industry", "headquarters", "subsidiaries"]
          verification: "business registry lookup"
        brands:
          fields: ["name", "parent_company", "category", "market_presence"]
          verification: "trademark database"
        government_entities:
          fields: ["name", "jurisdiction", "type", "officials"]
          verification: "official government records"

    vote_tracking:
      user_history:
        storage: "encrypted local storage + backup hash on-chain"
        fields: ["campaign_id", "vote_choice", "timestamp", "nullifier_hash"]
        privacy: "only user can decrypt their own history"
      revocation_system:
        window: "configurable per campaign (default: until campaign end)"
        process: "submit new vote with same nullifier"
        verification: "nullifier uniqueness ensures single active vote"

    results:
      aggregation:
        method: "zk-tally (recommended)"
        updates: "every block confirmation"
        caching: "Redis for fast API responses"
      transparency:
        vote_proofs: "publicly verifiable without revealing votes"
        audit_trail: "complete blockchain history"
        statistical_analysis: "demographic breakdowns (anonymized)"

    visualization_dashboard:
      metrics:
        - "total_votes_per_campaign"
        - "vote_distribution_charts"
        - "trending_campaigns"
        - "geographic_vote_patterns"
        - "time_series_vote_progression"
        - "impact_scores_per_entity"
      chart_types:
